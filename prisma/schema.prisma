generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Cliente {
  id       Int       @id @default(autoincrement())
  nome     String    @db.VarChar(40)
  email    String    @db.VarChar(60)
  obs      String?   @db.Text
  reservas Reserva[]

  @@map("clientes")
}

model Viagem {
  id          Int         @id @default(autoincrement())
  destino     String      @db.VarChar(60)
  transporte  Transportes @default(Terrestre)
  dataSaida   DateTime
  dataRetorno DateTime
  roteiro     String?     @db.Text
  localSaida  String?     @db.Text
  Nvagas      Int
  Nreservas   Int         @default(0)
  reservas    Reserva[]

  @@map("viagens")
}

model Reserva {
  id        Int     @id @default(autoincrement())
  clienteId Int
  viagemId  Int
  pacote    Pacotes
  preco     Decimal @db.Decimal(9, 2)

  cliente Cliente @relation(fields: [clienteId], references: [id])
  viagem  Viagem  @relation(fields: [viagemId], references: [id])

  @@map("reservas")
}

enum Pacotes {
  Aereo
  Turistico
  Hospedagem
  Experiência
  SeguroViagem
}

enum Transportes {
  Aereo
  Maritmo
  Terrestre
}
